---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = '/og-image.jpg',
} = Astro.props;

const siteURL = 'https://burofaxlegal.es';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteURL}${ogImage}`} />
    <meta property="og:locale"      content="es_ES" />
    <meta property="og:site_name"   content="Burofax Legal" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteURL}${ogImage}`} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Schema.org JSON-LD — LegalService -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LegalService",
      "name": "Burofax Legal",
      "description": "Servicio online de redacción jurídica y envío de burofax por abogado. Precio cerrado y tramitación 100% online.",
      "url": siteURL,
      "logo": `${siteURL}/favicon.svg`,
      "priceRange": "179€ - 249€",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Tarjeta de crédito, transferencia bancaria",
      "areaServed": { "@type": "Country", "name": "España" },
      "availableLanguage": "Spanish",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de burofax",
        "itemListElement": [
          {
            "@type": "Offer",
            "name": "Servicio Estándar",
            "description": "Redacción jurídica y envío de burofax en 24/48 h laborables.",
            "price": "179",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "name": "Servicio Urgente",
            "description": "Redacción reforzada y envío de burofax el mismo día laborable.",
            "price": "249",
            "priceCurrency": "EUR"
          }
        ]
      }
    })} />

    <!-- TODO: Añadir aquí Google Analytics / Meta Pixel cuando esté disponible -->
    <!-- Ejemplo GA4:
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    -->
  </head>

  <body>
    <slot />

    <!-- IntersectionObserver para animaciones al scroll -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = parseInt(el.dataset.delay || '0', 10);
              setTimeout(() => {
                el.classList.add('is-visible');
              }, delay);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.12 }
      );

      document
        .querySelectorAll('.animate-on-scroll')
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
