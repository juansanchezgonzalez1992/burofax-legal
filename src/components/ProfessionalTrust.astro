---
const trustBlocks = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M14 3L4 8v8c0 5.5 4.5 8.5 10 10 5.5-1.5 10-4.5 10-10V8L14 3z" stroke="#1B2B4B" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 14l3.5 3.5 7-7" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Redacción por abogado',
    text: 'El burofax lo prepara un profesional con criterio jurídico, no una plantilla automática.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><rect x="5" y="7" width="18" height="14" rx="2" stroke="#1B2B4B" stroke-width="1.8"/><path d="M9 7V5a2 2 0 014 0v2M15 7V5a2 2 0 014 0v2" stroke="#1B2B4B" stroke-width="1.8" stroke-linecap="round"/><path d="M9 14h10M9 18h6" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    title: 'Precio cerrado',
    text: 'Sabes cuánto pagas antes de empezar. Sin costes añadidos ni sorpresas en la factura.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><circle cx="14" cy="14" r="10" stroke="#1B2B4B" stroke-width="1.8"/><path d="M9 14l5-5 5 5M14 9v10" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Tramitación online',
    text: 'Todo el proceso se gestiona por internet, sin desplazamientos ni citas presenciales.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M5 7h18M5 14h12M5 20h15" stroke="#1B2B4B" stroke-width="1.8" stroke-linecap="round"/><circle cx="22" cy="19" r="4" fill="rgba(201,168,76,0.15)" stroke="#C9A84C" stroke-width="1.5"/><path d="M20.5 19l1 1 2-2" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Documentación acreditativa',
    text: 'Se genera documentación que acredita el contenido y la fecha del envío.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><path d="M14 4v10l5 5" stroke="#1B2B4B" stroke-width="1.8" stroke-linecap="round"/><circle cx="14" cy="14" r="10" stroke="#C9A84C" stroke-width="1.8"/></svg>`,
    title: 'Sin desplazamientos',
    text: 'Puedes solicitar el servicio desde cualquier lugar de España.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><circle cx="14" cy="14" r="10" stroke="#1B2B4B" stroke-width="1.8"/><path d="M10 14l2.5 2.5 6-6" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Sin promesas falsas',
    text: 'No garantizamos resultados ni prometemos lo que no está en nuestra mano. Solo hacemos bien lo que nos corresponde.',
  },
];
---

<section class="pro-trust section section--surface" id="confianza">
  <div class="container">
    <div class="section-header animate-on-scroll" data-animate="fade-up">
      <h2>Un servicio real, con abogado, precio cerrado y sin letra pequeña</h2>
    </div>

    <div class="pro-trust__grid animate-on-scroll" data-animate="fade-up" data-delay="100">
      {trustBlocks.map((block) => (
        <div class="pro-trust__block">
          <span class="pro-trust__icon" set:html={block.icon} />
          <h3 class="pro-trust__block-title">{block.title}</h3>
          <p class="pro-trust__block-text">{block.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .pro-trust__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: 0;
  }

  .pro-trust__block {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pro-trust__icon {
    display: flex;
    width: 28px;
    height: 28px;
  }

  .pro-trust__block-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.25;
  }

  .pro-trust__block-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  @media (min-width: 640px) {
    .pro-trust__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pro-trust__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
