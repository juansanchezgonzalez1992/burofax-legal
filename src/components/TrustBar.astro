---
const items = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.7 5.5 6.1 0.9-4.4 4.3 1 6.1L12 16l-5.4 2.8 1-6.1L3.2 8.4l6.1-0.9L12 2z" stroke="#C9A84C" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
    strong: 'Borrador revisable',
    text: 'Apruebas el texto antes del envío',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C8 5.5 4 6 4 6v7c0 4.5 4 7.5 8 9 4-1.5 8-4.5 8-9V6s-4-.5-8-4z" stroke="#C9A84C" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    strong: 'Abogados colegiados',
    text: 'en ejercicio activo',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v20M2 12h20" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="12" r="9" stroke="#C9A84C" stroke-width="1.8"/></svg>`,
    strong: 'Precio cerrado',
    text: 'IVA incluido. Sin costes ocultos.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="14" rx="2" stroke="#C9A84C" stroke-width="1.8"/><path d="M7 8h10M7 12h6" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    strong: 'Tramitación online',
    text: 'Sin desplazamientos ni esperas',
  },
];
---

<section class="trust-bar" aria-label="Datos de confianza">
  <div class="container">
    <ul class="trust-bar__grid">
      {items.map((item, i) => (
        <li class={`trust-bar__item${i > 0 ? ' trust-bar__item--border' : ''}`}>
          <span class="trust-bar__icon" set:html={item.icon} />
          <div class="trust-bar__text">
            <strong>{item.strong}</strong>
            <span>{item.text}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-bar {
    background-color: var(--color-primary);
    color: #fff;
    padding-block: var(--space-6);
  }

  .trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .trust-bar__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .trust-bar__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .trust-bar__text strong {
    font-size: var(--text-sm);
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
  }

  .trust-bar__text span {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .trust-bar__grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .trust-bar__item--border {
      border-left: 1px solid rgba(255, 255, 255, 0.12);
      padding-left: var(--space-6);
    }
  }
</style>
