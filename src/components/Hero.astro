---
---

<section class="hero section" id="servicio" aria-label="Presentación del servicio">
  <div class="container hero__inner">

    <!-- Columna de texto -->
    <div class="hero__text animate-on-scroll" data-animate="fade-up">
      <span class="badge badge--gold hero__badge">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 1l1.5 3.2L12 4.8l-2.5 2.4.6 3.4L7 9l-3.1 1.6.6-3.4L2 4.8l3.5-.6L7 1z" fill="currentColor"/>
        </svg>
        Redactado por abogado colegiado
      </span>

      <h1 class="hero__title">
        Burofax redactado por abogado para reclamar deudas, alquileres e incumplimientos sin cometer errores
      </h1>

      <p class="hero__subtitle">
        Redactamos y enviamos tu burofax con prueba de lo que envías y cuándo,
        precio cerrado y tramitación online. Para reclamar formalmente antes de
        negociar o si necesitas dejar constancia antes de actuar.
      </p>

      <div class="hero__ctas">
        <a href="#contacto" class="btn btn--gold btn--lg">
          Solicitar redacción y envío
        </a>
        <a href="#casos" class="btn btn--outline btn--lg">
          Ver casos habituales
        </a>
      </div>

      <ul class="hero__trust-mini" aria-label="Características del servicio">
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4.5" stroke="#27AE60" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Redacción por abogado
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4.5" stroke="#27AE60" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Envío online
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4.5" stroke="#27AE60" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Prueba de contenido
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4.5" stroke="#27AE60" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Precio cerrado
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8l3.5 3.5L13 4.5" stroke="#27AE60" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          24/48&nbsp;h laborables
        </li>
      </ul>
    </div>

    <!-- Tarjeta lateral de precio -->
    <div class="hero__card-wrap animate-on-scroll" data-animate="fade-in" data-delay="150">
      <div class="hero__card">
        <div class="hero__card-tag">Precio cerrado</div>

        <div class="hero__price">
          <span class="hero__price-from">Desde</span>
          <span class="hero__price-amount">179&nbsp;€</span>
          <span class="hero__price-vat">IVA incluido</span>
        </div>

        <ul class="hero__card-features">
          <li>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 7.5l3.5 3.5 6.5-6.5" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Redacción jurídica por abogado
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 7.5l3.5 3.5 6.5-6.5" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Envío con acuse de recibo
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 7.5l3.5 3.5 6.5-6.5" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Documentación acreditativa
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 7.5l3.5 3.5 6.5-6.5" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Sin desplazamientos
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 7.5l3.5 3.5 6.5-6.5" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Proceso 100&nbsp;% online
          </li>
        </ul>

        <a href="#contacto" class="btn btn--primary btn--full">Solicitar ahora</a>

        <p class="hero__card-note">
          Sin compromiso inicial. Nos ponemos en contacto para confirmar disponibilidad.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: linear-gradient(160deg, var(--color-bg) 0%, #EEF0F5 100%);
    padding-block: var(--space-20);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Badge */
  .hero__badge {
    margin-bottom: var(--space-5);
  }

  /* Title */
  .hero__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: var(--letter-spacing-heading);
    line-height: 1.1;
    margin-bottom: var(--space-6);
    position: relative;
    padding-left: var(--space-6);
  }

  .hero__title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15em;
    bottom: 0.15em;
    width: 4px;
    background: var(--color-gold);
    border-radius: var(--radius-full);
  }

  /* Subtitle */
  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: var(--space-4);
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  /* Trust mini */
  .hero__trust-mini {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
  }

  .hero__trust-mini li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Card */
  .hero__card-wrap {
    width: 100%;
  }

  .hero__card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    padding: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  .hero__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-gold));
  }

  .hero__card-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .hero__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .hero__price-from {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero__price-amount {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .hero__price-vat {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero__card-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .hero__card-features li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 500;
  }

  .hero__card-note {
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.5;
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1fr 400px;
      gap: var(--space-16);
      align-items: start;
    }

    .hero__card-wrap {
      position: sticky;
      top: calc(68px + var(--space-8));
    }
  }
</style>
